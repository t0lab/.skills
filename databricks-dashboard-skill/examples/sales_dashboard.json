{
  "datasets": [
    {
      "name": "ds_sales_summary",
      "displayName": "Sales Summary",
      "queryLines": [
        "SELECT\n",
        "  product_category,\n",
        "  DATE_TRUNC('MONTH', order_date) as order_month,\n",
        "  SUM(revenue) as total_revenue,\n",
        "  COUNT(DISTINCT order_id) as order_count,\n",
        "  AVG(revenue) as avg_order_value\n",
        "FROM catalog.schema.orders\n",
        "WHERE order_date >= :start_date\n",
        "GROUP BY product_category, DATE_TRUNC('MONTH', order_date)\n",
        "ORDER BY order_month, total_revenue DESC\n"
      ],
      "parameters": [
        {
          "displayName": "Start Date",
          "keyword": "start_date",
          "dataType": "DATE",
          "defaultSelection": {
            "values": {
              "dataType": "DATE",
              "values": [{"value": "2024-01-01"}]
            }
          }
        }
      ]
    },
    {
      "name": "ds_sales_kpi",
      "displayName": "Sales KPIs",
      "queryLines": [
        "SELECT\n",
        "  SUM(revenue) as total_revenue,\n",
        "  COUNT(DISTINCT order_id) as total_orders,\n",
        "  COUNT(DISTINCT customer_id) as unique_customers,\n",
        "  AVG(revenue) as avg_order_value,\n",
        "  order_date\n",
        "FROM catalog.schema.orders\n",
        "GROUP BY order_date\n",
        "ORDER BY order_date DESC\n"
      ]
    },
    {
      "name": "ds_sales_detail",
      "displayName": "Sales Detail",
      "queryLines": [
        "SELECT\n",
        "  order_id,\n",
        "  customer_name,\n",
        "  product_category,\n",
        "  product_name,\n",
        "  revenue,\n",
        "  order_date\n",
        "FROM catalog.schema.orders\n",
        "ORDER BY order_date DESC\n",
        "LIMIT 1000\n"
      ]
    }
  ],
  "pages": [
    {
      "name": "pg_overview",
      "displayName": "Sales Overview",
      "pageType": "PAGE_TYPE_CANVAS",
      "layout": [
        {
          "widget": {
            "name": "w_title",
            "textbox_spec": "# 📊 Sales Dashboard\n\nReal-time sales performance overview."
          },
          "position": {"x": 0, "y": 0, "width": 6, "height": 1}
        },
        {
          "widget": {
            "name": "w_filter_category",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "ds_sales_summary",
                  "fields": [{"name": "product_category", "expression": "`product_category`"}],
                  "disaggregated": false
                }
              }
            ],
            "spec": {
              "version": 2,
              "widgetType": "filter-multi-select",
              "encodings": {
                "fields": [
                  {"fieldName": "product_category", "displayName": "Product Category", "queryName": "main_query"}
                ]
              }
            }
          },
          "position": {"x": 0, "y": 1, "width": 2, "height": 1}
        },
        {
          "widget": {
            "name": "w_kpi_revenue",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "ds_sales_kpi",
                  "fields": [
                    {"name": "total_revenue", "expression": "`total_revenue`"},
                    {"name": "order_date", "expression": "`order_date`"}
                  ],
                  "disaggregated": false
                }
              }
            ],
            "spec": {
              "version": 2,
              "widgetType": "counter",
              "encodings": {
                "value": {"fieldName": "total_revenue", "transform": "SUM"},
                "sparkline": {"fieldName": "order_date"}
              },
              "frame": {"showTitle": true, "title": "Total Revenue"}
            }
          },
          "position": {"x": 0, "y": 2, "width": 2, "height": 2}
        },
        {
          "widget": {
            "name": "w_kpi_orders",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "ds_sales_kpi",
                  "fields": [
                    {"name": "total_orders", "expression": "`total_orders`"},
                    {"name": "order_date", "expression": "`order_date`"}
                  ],
                  "disaggregated": false
                }
              }
            ],
            "spec": {
              "version": 2,
              "widgetType": "counter",
              "encodings": {
                "value": {"fieldName": "total_orders", "transform": "SUM"},
                "sparkline": {"fieldName": "order_date"}
              },
              "frame": {"showTitle": true, "title": "Total Orders"}
            }
          },
          "position": {"x": 2, "y": 2, "width": 2, "height": 2}
        },
        {
          "widget": {
            "name": "w_kpi_customers",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "ds_sales_kpi",
                  "fields": [
                    {"name": "unique_customers", "expression": "`unique_customers`"},
                    {"name": "order_date", "expression": "`order_date`"}
                  ],
                  "disaggregated": false
                }
              }
            ],
            "spec": {
              "version": 2,
              "widgetType": "counter",
              "encodings": {
                "value": {"fieldName": "unique_customers", "transform": "SUM"},
                "sparkline": {"fieldName": "order_date"}
              },
              "frame": {"showTitle": true, "title": "Unique Customers"}
            }
          },
          "position": {"x": 4, "y": 2, "width": 2, "height": 2}
        },
        {
          "widget": {
            "name": "w_revenue_trend",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "ds_sales_summary",
                  "fields": [
                    {"name": "order_month", "expression": "`order_month`"},
                    {"name": "total_revenue", "expression": "`total_revenue`"},
                    {"name": "product_category", "expression": "`product_category`"}
                  ],
                  "disaggregated": false
                }
              }
            ],
            "spec": {
              "version": 3,
              "widgetType": "line",
              "encodings": {
                "x": {"fieldName": "order_month", "scale": {"type": "temporal"}, "displayName": "Month"},
                "y": {"fieldName": "total_revenue", "scale": {"type": "quantitative"}, "transform": "SUM", "displayName": "Revenue"},
                "color": {"fieldName": "product_category", "displayName": "Category"}
              },
              "frame": {"showTitle": true, "title": "Revenue Trend by Category"}
            }
          },
          "position": {"x": 0, "y": 4, "width": 6, "height": 6}
        },
        {
          "widget": {
            "name": "w_category_bar",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "ds_sales_summary",
                  "fields": [
                    {"name": "product_category", "expression": "`product_category`"},
                    {"name": "total_revenue", "expression": "`total_revenue`"}
                  ],
                  "disaggregated": false
                }
              }
            ],
            "spec": {
              "version": 3,
              "widgetType": "bar",
              "encodings": {
                "x": {"fieldName": "product_category", "scale": {"type": "categorical"}, "displayName": "Category"},
                "y": {"fieldName": "total_revenue", "scale": {"type": "quantitative"}, "transform": "SUM", "displayName": "Revenue"},
                "label": {"show": true}
              },
              "frame": {"showTitle": true, "title": "Revenue by Category"},
              "mark": {"layout": "group"}
            }
          },
          "position": {"x": 0, "y": 10, "width": 3, "height": 5}
        },
        {
          "widget": {
            "name": "w_category_pie",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "ds_sales_summary",
                  "fields": [
                    {"name": "product_category", "expression": "`product_category`"},
                    {"name": "order_count", "expression": "`order_count`"}
                  ],
                  "disaggregated": false
                }
              }
            ],
            "spec": {
              "version": 3,
              "widgetType": "pie",
              "encodings": {
                "angle": {"fieldName": "order_count", "transform": "SUM", "displayName": "Orders"},
                "color": {"fieldName": "product_category", "displayName": "Category"}
              },
              "frame": {"showTitle": true, "title": "Order Distribution"}
            }
          },
          "position": {"x": 3, "y": 10, "width": 3, "height": 5}
        },
        {
          "widget": {
            "name": "w_detail_table",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "ds_sales_detail",
                  "fields": [
                    {"name": "order_id", "expression": "`order_id`"},
                    {"name": "customer_name", "expression": "`customer_name`"},
                    {"name": "product_category", "expression": "`product_category`"},
                    {"name": "product_name", "expression": "`product_name`"},
                    {"name": "revenue", "expression": "`revenue`"},
                    {"name": "order_date", "expression": "`order_date`"}
                  ],
                  "disaggregated": true
                }
              }
            ],
            "spec": {
              "version": 2,
              "widgetType": "table",
              "encodings": {
                "columns": [
                  {"fieldName": "order_id", "displayName": "Order ID", "type": "string", "order": 0},
                  {"fieldName": "customer_name", "displayName": "Customer", "type": "string", "order": 1},
                  {"fieldName": "product_category", "displayName": "Category", "type": "string", "order": 2},
                  {"fieldName": "product_name", "displayName": "Product", "type": "string", "order": 3},
                  {"fieldName": "revenue", "displayName": "Revenue", "type": "number", "order": 4},
                  {"fieldName": "order_date", "displayName": "Date", "type": "date", "order": 5}
                ]
              },
              "frame": {"showTitle": true, "title": "Recent Orders"}
            }
          },
          "position": {"x": 0, "y": 15, "width": 6, "height": 6}
        }
      ]
    }
  ]
}
